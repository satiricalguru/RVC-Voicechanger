{
  "name": "rvc-voicechanger",
  "version": "1.0.0",
  "description": "RVC Voicechanger - Real-time RVC voice conversion desktop app",
  "main": "electron/main.js",
  "scripts": {
    "dev": "electron .",
    "prestart": "pnpm --prefix ui build",
    "start": "electron .",
    "build": "pnpm --prefix ui build && electron-builder --mac --x64 --arm64",
    "package": "electron-builder --dir"
  },
  "build": {
    "appId": "com.rvcvoicechanger.app",
    "productName": "RVC Voicechanger",
    "asar": false,
    "mac": {
      "target": "dmg",
      "category": "public.app-category.music",
      "icon": "assets/icon.icns"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "app/**/*"
    ]
  },
  "keywords": ["voice-changer", "rvc", "electron", "ai", "audio"],
  "author": "RVC Voicechanger",
  "license": "MIT",
  "devDependencies": {
    "electron": "33.4.11",
    "electron-builder": "25.1.8"
  },
  "dependencies": {
    "electron-store": "^10.0.0"
  }
}
